# LinkedIn Feed Intelligence Agent - Environment Variables
# Copy this to .env and fill in your values

# ── LLM Provider (pick ONE, comment out others) ──────────────────────────────

# Option 1: Google Gemini (RECOMMENDED - free tier available)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Groq (very fast, free tier)
# Get key at: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here

# ── LinkedIn Credentials (for cookie-based login) ────────────────────────────
# These are used ONCE to log in and save session cookies
# After that, cookies handle everything - no re-login needed
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# ── Config ───────────────────────────────────────────────────────────────────
# How many posts to collect per run
POSTS_TO_COLLECT=15

# Run browser visibly (True) or hidden (False)
# Recommended: True while testing, False for production
HEADLESS=False

# ── Notion Integration ───────────────────────────────────────────────────────
# Step 1: Go to https://www.notion.so/my-integrations
# Step 2: Click "New Integration" → name it "LinkedIn Agent" → Submit
# Step 3: Copy the "Internal Integration Secret" below
NOTION_TOKEN=your_notion_token

# Step 4: Create an empty page in Notion (this is where the DB will live)
# Step 5: Open it in browser → URL looks like:
#   notion.so/Your-Workspace/My-Page-abc123def456...
# Step 6: Copy the last part (32 chars) as the page ID
# Step 7: On that page → click ··· (top right) → Connections → Add your integration
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id

# ── Browserbase (Path B — optional) ─────────────────────────────────────────
# Set USE_BROWSERBASE=true to switch from local Playwright to Browserbase cloud.
# Browserbase = stealth mode + CAPTCHA solving + verified browser.
# Costs: Free tier (1hr total) → Developer $20/mo (100hrs) → Startup $99/mo (500hrs)
# For daily use tracking 10 profiles (~20 min/day = 10 hrs/month) → Developer plan needed.
#
# Sign up: browserbase.com
# Get keys: browserbase.com/settings

USE_BROWSERBASE=false
BROWSERBASE_API_KEY=bb_live_your_key_here
BROWSERBASE_PROJECT_ID=proj_your_project_id_here
